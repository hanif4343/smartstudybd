<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Splash screen theme -->
    <style name="Theme.SmartStudy.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#4F46E5</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_round</item>
        <item name="windowSplashScreenAnimationDuration">500</item>
        <item name="postSplashScreenTheme">@style/Theme.SmartStudy</item>
    </style>

    <!-- Main app theme — AppCompat NoActionBar (Compose handles the rest) -->
    <style name="Theme.SmartStudy" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">#4F46E5</item>
        <item name="colorPrimaryDark">#4338CA</item>
        <item name="colorAccent">#10B981</item>
        <item name="android:statusBarColor">#4F46E5</item>
        <item name="android:windowBackground">#F1F5F9</item>
    </style>
</resources>
