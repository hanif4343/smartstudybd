{
  "rules": {
    ".read": true,
    ".write": "auth != null",
    "users": {
      ".indexOn": ["Phone", "phone"]
    },
    "Challenges": {
      "$challengeId": {
        ".read": true,
        ".write": true
      }
    },
    "Invites": {
      "$phone": {
        ".read": true,
        ".write": true
      }
    },
    "Reports": {
      ".write": true
    },
    "MatchHistory": {
      "$myPhone": {
        "$opponentPhone": {
          ".indexOn": ["playedAt"]
        }
      }
    }
  }
}
